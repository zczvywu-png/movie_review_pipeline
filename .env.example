# ============================================================
# Environment variables template
# Copy this file to .env and fill in real keys.
# ============================================================

# OpenAI API Key (required for sentiment annotation, synthetic reviews, and the agent)
# If you use a relay endpoint inside China, change OPENAI_BASE_URL accordingly
# (e.g. https://api.openai-proxy.org/v1)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# TMDB API Key (required for poster scraping)
# Free registration: https://www.themoviedb.org/settings/api
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: YouTube Data API key (main pipeline uses youtube-comment-downloader so this is not required)
# YOUTUBE_API_KEY=
